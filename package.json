{
  "name": "crew",
  "version": "0.2.0",
  "description": "多模型协作 coding 工具：一个指挥模型调度多个工作模型干活",
  "type": "module",
  "bin": {
    "crew": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "start": "tsx src/index.ts",
